<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>👑 لوحة الأونر</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="dark-bg">
<%- include('partials/header', { user, botAvatar: botAvatar||'', isOwner: true }) %>

<div style="padding-top:calc(var(--nav-h,62px) + 1.5rem)">
<div style="max-width:1200px;margin:0 auto;padding:0 1.5rem 3rem">
  <div id="toast" class="toast hidden"></div>

  <!-- Header -->
  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:2rem;flex-wrap:wrap">
    <div>
      <h1 style="font-size:1.9rem;font-weight:900">👑 لوحة الأونر</h1>
      <p style="color:var(--text-secondary);margin-top:.3rem">تحكم كامل في البوت وإدارة Premium</p>
    </div>
    <div style="margin-right:auto;display:flex;align-items:center;gap:.6rem;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.3);padding:.5rem 1rem;border-radius:12px">
      <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" style="width:32px;height:32px;border-radius:50%" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
      <span style="color:#f59e0b;font-weight:700">مرحباً، <%= user.username %></span>
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:1rem;margin-bottom:2rem">
    <% [
      {icon:'🏠', num:stats.guilds,                      label:'سيرفر'},
      {icon:'👥', num:stats.users.toLocaleString(),       label:'مستخدم'},
      {icon:'📡', num:stats.ping+'ms',                   label:'البينج'},
      {icon:'👑', num:guilds.filter(g=>g.premium).length, label:'Premium'},
      {icon:'⏱️', num:Math.floor((stats.uptime||0)/3600)+'h', label:'تشغيل'},
    ].forEach(s => { %>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.2rem;text-align:center">
      <div style="font-size:2rem"><%= s.icon %></div>
      <div style="font-size:1.75rem;font-weight:900;color:var(--accent);line-height:1.2"><%= s.num %></div>
      <div style="font-size:.8rem;color:var(--text-secondary);margin-top:.2rem"><%= s.label %></div>
    </div>
    <% }) %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem">

    <!-- Premium Management -->
    <div style="background:var(--bg-card);border:1px solid rgba(245,158,11,.25);border-radius:14px;padding:1.5rem">
      <h2 style="font-size:1.05rem;font-weight:800;margin-bottom:1.1rem;color:#f59e0b">👑 إدارة Premium</h2>
      <div style="margin-bottom:.8rem">
        <label style="display:block;font-size:.8rem;color:var(--text-secondary);margin-bottom:.35rem">🏠 ID السيرفر</label>
        <input type="text" id="pm_id" placeholder="123456789..." style="width:100%;background:#0a0a1e;border:1px solid var(--border);border-radius:9px;color:var(--text-primary);padding:.55rem .8rem;font-family:inherit;font-size:.87rem;outline:none">
      </div>
      <div style="margin-bottom:1rem">
        <label style="display:block;font-size:.8rem;color:var(--text-secondary);margin-bottom:.35rem">📅 عدد الأيام</label>
        <input type="number" id="pm_days" value="30" min="1" max="3650" style="width:100%;background:#0a0a1e;border:1px solid var(--border);border-radius:9px;color:var(--text-primary);padding:.55rem .8rem;font-family:inherit;font-size:.87rem;outline:none">
      </div>
      <div style="display:flex;gap:.6rem">
        <button onclick="managePremium('add')" style="flex:1;background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;border:none;border-radius:9px;padding:.6rem;font-family:inherit;font-weight:700;cursor:pointer;font-size:.88rem">✅ منح</button>
        <button onclick="managePremium('remove')" style="flex:1;background:rgba(239,68,68,.12);color:#ef4444;border:1px solid rgba(239,68,68,.25);border-radius:9px;padding:.6rem;font-family:inherit;font-weight:700;cursor:pointer;font-size:.88rem">❌ سحب</button>
      </div>
      <div id="pm-result" style="margin-top:.75rem;font-size:.85rem;font-weight:700;min-height:1.2rem"></div>
    </div>

    <!-- Quick Info -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.5rem">
      <h2 style="font-size:1.05rem;font-weight:800;margin-bottom:1.1rem">⚡ معلومات سريعة</h2>
      <div style="display:flex;flex-direction:column;gap:.5rem">
        <% [
          {label:'السيرفرات', val:stats.guilds},
          {label:'Premium مفعّل', val:guilds.filter(g=>g.premium).length},
          {label:'إجمالي الأعضاء', val:stats.users.toLocaleString()},
          {label:'البينج', val:stats.ping+'ms'},
        ].forEach(item => { %>
        <div style="background:#0a0a1e;border-radius:8px;padding:.65rem .9rem;font-size:.84rem;display:flex;justify-content:space-between;align-items:center">
          <span style="color:var(--text-secondary)"><%= item.label %></span>
          <strong><%= item.val %></strong>
        </div>
        <% }) %>
        <a href="/dashboard" style="display:flex;align-items:center;justify-content:center;gap:.5rem;background:rgba(124,58,237,.1);color:#a78bfa;border:1px solid rgba(124,58,237,.2);border-radius:9px;padding:.6rem;text-decoration:none;font-weight:600;font-size:.87rem;margin-top:.3rem">← رجوع للداشبورد</a>
      </div>
    </div>
  </div>

  <!-- Guilds Table -->
  <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.5rem">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.2rem;flex-wrap:wrap">
      <h2 style="font-size:1.05rem;font-weight:800">🏠 جميع السيرفرات (<%= guilds.length %>)</h2>
      <input type="text" id="guild-search" oninput="filterGuilds(this.value)" placeholder="🔍 ابحث..." style="background:#0a0a1e;border:1px solid var(--border);border-radius:9px;color:var(--text-primary);padding:.45rem .8rem;font-family:inherit;font-size:.85rem;outline:none;width:200px">
    </div>
    <div id="guilds-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:.85rem">
      <% guilds.forEach(g => { %>
      <div class="owner-guild-card" data-name="<%= g.name.toLowerCase() %>"
        style="background:#0a0a1e;border:1px solid <%= g.premium ? 'rgba(245,158,11,.35)' : 'rgba(255,255,255,.05)' %>;border-radius:12px;padding:.9rem;position:relative">
        <% if(g.premium) { %><div style="position:absolute;top:.5rem;left:.5rem;background:rgba(245,158,11,.15);color:#f59e0b;padding:.12rem .45rem;border-radius:20px;font-size:.67rem;font-weight:700">👑</div><% } %>
        <div style="display:flex;align-items:center;gap:.65rem;margin-bottom:.7rem">
          <img src="<%= g.icon %>" style="width:38px;height:38px;border-radius:9px;object-fit:cover;flex-shrink:0" onerror="this.style.display='none'">
          <div style="min-width:0">
            <div style="font-weight:700;font-size:.87rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:130px"><%= g.name %></div>
            <div style="font-size:.72rem;color:var(--text-secondary)"><%= (g.memberCount||0).toLocaleString() %> عضو</div>
          </div>
        </div>
        <code onclick="copyId('<%= g.id %>')" title="انقر للنسخ" style="display:block;font-size:.69rem;color:var(--text-secondary);background:rgba(255,255,255,.04);padding:.28rem .45rem;border-radius:6px;cursor:pointer;margin-bottom:.6rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= g.id %></code>
        <div style="display:flex;gap:.35rem">
          <a href="/dashboard/<%= g.id %>" style="flex:1;text-align:center;background:rgba(124,58,237,.12);color:#a78bfa;border:1px solid rgba(124,58,237,.18);border-radius:7px;padding:.32rem;text-decoration:none;font-size:.75rem;font-weight:600">⚙️ إدارة</a>
          <button onclick="quickPremium('<%= g.id %>',<%= g.premium %>)" style="flex:1;background:<%= g.premium ? 'rgba(239,68,68,.1)' : 'rgba(245,158,11,.1)' %>;color:<%= g.premium ? '#ef4444' : '#f59e0b' %>;border:1px solid <%= g.premium ? 'rgba(239,68,68,.2)' : 'rgba(245,158,11,.2)' %>;border-radius:7px;padding:.32rem;cursor:pointer;font-size:.75rem;font-weight:700;font-family:inherit"><%= g.premium ? '❌' : '✅' %></button>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>
</div>

<script>
function showToast(msg, type='success') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast ' + type;
  setTimeout(() => t.className = 'toast hidden', 3500);
}
async function managePremium(action) {
  const guildId = document.getElementById('pm_id').value.trim();
  const days = document.getElementById('pm_days').value;
  if (!guildId) return showToast('❌ أدخل ID السيرفر', 'error');
  const r = await fetch('/api/owner/premium', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ guildId, days, action }) });
  const d = await r.json();
  const res = document.getElementById('pm-result');
  res.textContent = d.message || d.error || '';
  res.style.color = d.success ? '#10b981' : '#ef4444';
  showToast(d.success ? d.message : d.error || 'خطأ!', d.success ? 'success' : 'error');
}
async function quickPremium(guildId, hasPremium) {
  const r = await fetch('/api/owner/premium', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ guildId, days:30, action: hasPremium ? 'remove' : 'add' }) });
  const d = await r.json();
  showToast(d.message || d.error, d.success ? 'success' : 'error');
  if (d.success) setTimeout(() => location.reload(), 1200);
}
function copyId(id) {
  navigator.clipboard.writeText(id).then(() => showToast('✅ تم نسخ الـ ID'));
}
function filterGuilds(q) {
  document.querySelectorAll('.owner-guild-card').forEach(c => {
    c.style.display = c.dataset.name.includes(q.toLowerCase()) ? '' : 'none';
  });
}
</script>
</body>
</html>
