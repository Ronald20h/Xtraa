<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة الأونر | Xtra Bot</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/nav') %>
<div style="padding-top:var(--nav-h);">
<div class="dashboard-layout">
<div class="sidebar">
  <div class="sidebar-guild">
    <div class="guild-avatar">👑</div>
    <div><div class="guild-name">لوحة الأونر</div><div class="guild-meta">STEVEN</div></div>
  </div>
  <div class="sidebar-section">التحكم</div>
  <a href="#stats" class="sidebar-link active" onclick="setActive(this)"><i class="fas fa-chart-bar"></i> <span>الإحصائيات</span></a>
  <a href="#premium" class="sidebar-link" onclick="setActive(this)"><i class="fas fa-crown"></i> <span>إدارة البريميوم</span></a>
  <a href="#guilds" class="sidebar-link" onclick="setActive(this)"><i class="fas fa-server"></i> <span>السيرفرات</span></a>
  <a href="#broadcast" class="sidebar-link" onclick="setActive(this)"><i class="fas fa-broadcast-tower"></i> <span>الإذاعة</span></a>
</div>
<div class="content">
  <% if (typeof query !== 'undefined') { %>
    <% if (query.granted) { %><div class="alert alert-success"><i class="fas fa-crown"></i> تم منح البريميوم بنجاح!</div><% } %>
    <% if (query.revoked) { %><div class="alert alert-error"><i class="fas fa-times"></i> تم سحب البريميوم</div><% } %>
    <% if (query.broadcast) { %><div class="alert alert-info"><i class="fas fa-broadcast-tower"></i> تم الإرسال لـ <%= query.broadcast %> سيرفر</div><% } %>
  <% } %>

  <!-- Stats -->
  <div id="stats">
    <div class="page-header"><h1><i class="fas fa-chart-bar text-accent"></i> إحصائيات البوت</h1></div>
    <div class="owner-stats">
      <div class="owner-stat">
        <div class="owner-stat-icon">🌐</div>
        <div><div class="owner-stat-value"><%= totalGuilds %></div><div class="owner-stat-label">سيرفر</div></div>
      </div>
      <div class="owner-stat">
        <div class="owner-stat-icon">👥</div>
        <div><div class="owner-stat-value"><%= totalUsers %></div><div class="owner-stat-label">مستخدم</div></div>
      </div>
      <div class="owner-stat">
        <div class="owner-stat-icon">💎</div>
        <div><div class="owner-stat-value"><%= premiums ? premiums.length : 0 %></div><div class="owner-stat-label">سيرفر بريميوم</div></div>
      </div>
      <div class="owner-stat">
        <div class="owner-stat-icon">💓</div>
        <div><div class="owner-stat-value"><%= ping %>ms</div><div class="owner-stat-label">Ping</div></div>
      </div>
    </div>
  </div>

  <hr class="divider">

  <!-- Premium Management -->
  <div id="premium">
    <div class="page-header"><h1><i class="fas fa-crown text-gold"></i> إدارة البريميوم</h1></div>
    <div class="card">
      <div class="card-title"><i class="fas fa-plus text-accent"></i> منح البريميوم</div>
      <form method="POST" action="/owner/premium/grant">
        <div class="form-row">
          <div class="form-group">
            <label>🆔 Server ID</label>
            <input class="form-control" name="guild_id" placeholder="1234567890..." required>
          </div>
          <div class="form-group">
            <label>📦 الباقة</label>
            <select class="form-control" name="plan">
              <option value="basic">⭐ Basic</option>
              <option value="pro">💎 Pro</option>
              <option value="unlimited">🚀 Unlimited</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>📅 تاريخ الانتهاء (اتركه فارغاً للأبد)</label>
          <input class="form-control" type="date" name="expires_at">
        </div>
        <button class="btn btn-gold" type="submit"><i class="fas fa-crown"></i> منح البريميوم</button>
      </form>
    </div>

    <% if (premiums && premiums.length) { %>
    <div class="card">
      <div class="card-title"><i class="fas fa-list text-gold"></i> السيرفرات المميزة (<%= premiums.length %>)</div>
      <div class="table-wrap">
        <table>
          <tr><th>السيرفر</th><th>الباقة</th><th>الانتهاء</th><th>بواسطة</th><th>إجراء</th></tr>
          <% premiums.forEach(p => { %>
          <tr>
            <td><code><%= p.guild_id %></code></td>
            <td><span class="badge <%= p.plan === 'unlimited' ? 'badge-purple' : p.plan === 'pro' ? 'badge-gold' : 'badge-blue' %>"><%= p.plan %></span></td>
            <td style="color:var(--text2);font-size:.82rem;"><%= p.expires_at ? p.expires_at.split('T')[0] : '♾️ أبدي' %></td>
            <td style="color:var(--text2);font-size:.82rem;"><code><%= p.granted_by %></code></td>
            <td>
              <form method="POST" action="/owner/premium/revoke" style="display:inline;">
                <input type="hidden" name="guild_id" value="<%= p.guild_id %>">
                <button class="btn btn-danger btn-sm"><i class="fas fa-times"></i> سحب</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </table>
      </div>
    </div>
    <% } %>
  </div>

  <hr class="divider">

  <!-- Guilds -->
  <div id="guilds">
    <div class="page-header"><h1><i class="fas fa-server text-accent"></i> جميع السيرفرات (<%= totalGuilds %>)</h1></div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <tr><th>ID</th><th>اللغة</th><th>البريميوم</th><th>التاريخ</th></tr>
          <% guilds.slice(0, 30).forEach(g => { %>
          <tr>
            <td><code><%= g.id %></code></td>
            <td><span class="badge badge-blue"><%= g.lang || 'ar' %></span></td>
            <td><span class="badge <%= g.premium ? 'badge-gold' : 'badge-red' %>"><%= g.premium ? '✅ نعم' : '❌ لا' %></span></td>
            <td style="color:var(--text2);font-size:.8rem;"><%= g.created_at ? g.created_at.split('T')[0] : '—' %></td>
          </tr>
          <% }) %>
        </table>
      </div>
    </div>
  </div>

  <hr class="divider">

  <!-- Broadcast -->
  <div id="broadcast">
    <div class="page-header"><h1><i class="fas fa-broadcast-tower text-accent"></i> إذاعة عامة</h1></div>
    <div class="card">
      <div class="card-title"><i class="fas fa-paper-plane text-accent"></i> إرسال إعلان لجميع السيرفرات</div>
      <form method="POST" action="/owner/broadcast">
        <div class="form-group">
          <label>📢 نص الإعلان</label>
          <textarea class="form-control" name="message" rows="4" placeholder="اكتب إعلانك هنا..." required></textarea>
        </div>
        <button class="btn btn-accent" type="submit" onclick="return confirm('هل أنت متأكد من إرسال هذا الإعلان لجميع السيرفرات؟')">
          <i class="fas fa-paper-plane"></i> إرسال للكل
        </button>
      </form>
    </div>
  </div>
</div>
</div>
</div>
<%- include('../partials/footer') %>
<script>
function setActive(el){document.querySelectorAll('.sidebar-link').forEach(l=>l.classList.remove('active'));el.classList.add('active');}
</script>
</body>
</html>
