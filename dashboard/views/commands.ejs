<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>الأوامر | Xtra Bot</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>
<main style="padding-top:calc(var(--nav-h) + 2rem);">
<div class="section">
  <h1 class="section-title">⚡ قائمة الأوامر</h1>
  <p class="section-subtitle">جميع أوامر Xtra Bot مع الاختصارات والتفاصيل</p>

  <div style="display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;margin-bottom:2rem;">
    <% const cats = ['الكل','عام','إدارة','تذاكر','مستويات','ألعاب','حماية','بريميوم']; %>
    <% cats.forEach(c => { %>
    <button class="btn btn-secondary btn-sm filter-btn" data-cat="<%= c %>"><%= c %></button>
    <% }) %>
  </div>

  <div class="commands-grid" id="cmdsGrid">
    <% const allCmds = [
      {name:'help', cat:'عام', desc:'قائمة جميع الأوامر', shortcut:'!'},
      {name:'ping', cat:'عام', desc:'فحص سرعة البوت'},
      {name:'botinfo', cat:'عام', desc:'معلومات البوت'},
      {name:'userinfo', cat:'عام', desc:'معلومات عن عضو', shortcut:'يوزر'},
      {name:'serverinfo', cat:'عام', desc:'معلومات السيرفر'},
      {name:'avatar', cat:'عام', desc:'عرض صورة عضو'},
      {name:'decoration', cat:'عام', desc:'زخرفة النصوص بـ16 شكل ✨', shortcut:'زخرف'},
      {name:'afk', cat:'عام', desc:'وضع الغياب مع تغيير الاسم 💤'},
      {name:'giveaway', cat:'عام', desc:'نظام الهبات الكامل 🎉', shortcut:'هبة'},
      {name:'tax', cat:'عام', desc:'حاسبة الضريبة 💰', shortcut:'ضريبة'},
      {name:'weather', cat:'عام', desc:'حالة الطقس 🌤️'},
      {name:'translate', cat:'عام', desc:'ترجمة النصوص 🌍'},
      {name:'poll', cat:'عام', desc:'إنشاء استطلاع 📊'},
      {name:'suggest', cat:'عام', desc:'إرسال اقتراح 📝'},
      {name:'say', cat:'عام', desc:'إرسال رسالة كالبوت'},
      {name:'roleinfo', cat:'عام', desc:'معلومات رتبة'},
      {name:'remindme', cat:'عام', desc:'تعيين تذكير ⏰'},
      {name:'ban', cat:'إدارة', desc:'حظر عضو مع حذف رسائله'},
      {name:'kick', cat:'إدارة', desc:'طرد عضو من السيرفر'},
      {name:'mute', cat:'إدارة', desc:'كتم عضو بمدة محددة'},
      {name:'unmute', cat:'إدارة', desc:'رفع الكتم عن عضو'},
      {name:'warn', cat:'إدارة', desc:'تحذير عضو مع حفظ السجل'},
      {name:'warnings', cat:'إدارة', desc:'عرض تحذيرات عضو'},
      {name:'clearwarnings', cat:'إدارة', desc:'مسح تحذيرات عضو'},
      {name:'purge', cat:'إدارة', desc:'حذف رسائل دفعة واحدة'},
      {name:'lock', cat:'إدارة', desc:'قفل قناة'},
      {name:'unlock', cat:'إدارة', desc:'فتح قناة'},
      {name:'slowmode', cat:'إدارة', desc:'تفعيل الوضع البطيء'},
      {name:'addrole', cat:'إدارة', desc:'إضافة رتبة لعضو'},
      {name:'removerole', cat:'إدارة', desc:'إزالة رتبة من عضو'},
      {name:'rename', cat:'إدارة', desc:'تغيير اسم عضو 🆕', shortcut:'اسم'},
      {name:'come', cat:'إدارة', desc:'نداء عضو لقناة صوتية 🆕', shortcut:'تعال'},
      {name:'nickname', cat:'إدارة', desc:'تغيير اللقب مؤقتاً'},
      {name:'unban', cat:'إدارة', desc:'رفع الحظر عن عضو'},
      {name:'logs', cat:'إدارة', desc:'عرض سجل الإجراءات'},
      {name:'ticket setup', cat:'تذاكر', desc:'إعداد نظام التذاكر'},
      {name:'ticket panel', cat:'تذاكر', desc:'نشر لوحة التذاكر'},
      {name:'ticket close', cat:'تذاكر', desc:'إغلاق تذكرة'},
      {name:'ticket claim', cat:'تذاكر', desc:'استلام تذكرة للدعم'},
      {name:'ticket add', cat:'تذاكر', desc:'إضافة عضو للتذكرة'},
      {name:'ticket remove', cat:'تذاكر', desc:'إزالة عضو من التذكرة'},
      {name:'ticket rename', cat:'تذاكر', desc:'تغيير اسم التذكرة 🆕'},
      {name:'ticket list', cat:'تذاكر', desc:'قائمة التذاكر المفتوحة 🆕'},
      {name:'rank', cat:'مستويات', desc:'عرض رتبتك الحالية ومستواك', shortcut:'رتبة'},
      {name:'leaderboard', cat:'مستويات', desc:'لوحة المتصدرين', shortcut:'متصدرين'},
      {name:'setxp', cat:'مستويات', desc:'تعديل XP عضو (إدارة)'},
      {name:'roulette', cat:'ألعاب', desc:'روليت — راهن واربح 🎰', shortcut:'روليت'},
      {name:'xo', cat:'ألعاب', desc:'لعبة XO مع صديق ❌⭕', shortcut:'اكس'},
      {name:'dice', cat:'ألعاب', desc:'رمي النرد 🎲', shortcut:'نرد'},
      {name:'coinflip', cat:'ألعاب', desc:'رمي عملة 🪙'},
      {name:'rps', cat:'ألعاب', desc:'حجرة ورقة مقص ✊', shortcut:'حجرة'},
      {name:'guess', cat:'ألعاب', desc:'خمّن الرقم 🔢', shortcut:'خمن'},
      {name:'trivia', cat:'ألعاب', desc:'اختبار معلومات 🧠', shortcut:'ترvia'},
      {name:'protection', cat:'حماية', desc:'إعداد نظام الحماية الكامل'},
      {name:'premiuminfo', cat:'بريميوم', desc:'معلومات البريميوم 💎'},
      {name:'tokencheck', cat:'بريميوم', desc:'فحص التوكن (بريميوم فقط)'},
    ]; %>
    <% allCmds.forEach(c => { %>
    <div class="cmd-card" data-cat="<%= c.cat %>">
      <div class="cmd-name">/<%= c.name %></div>
      <div class="cmd-desc"><%= c.desc %></div>
      <% if (c.shortcut) { %>
        <div style="margin-top:.4rem;"><span style="font-size:.75rem;color:var(--text3);">اختصار: </span><span class="shortcut-key" style="font-size:.78rem;padding:.15rem .45rem;"><%= c.shortcut %></span></div>
      <% } %>
      <span class="cmd-cat"><%= c.cat %></span>
    </div>
    <% }) %>
  </div>
  <p style="text-align:center;color:var(--text2);margin-top:2rem;font-size:.9rem;">إجمالي: <strong style="color:var(--accent)"><%= allCmds ? allCmds.length : '55' %>+ أمر</strong></p>
</div>
</main>
<%- include('partials/footer') %>
<script>
const btns = document.querySelectorAll('.filter-btn');
btns.forEach(btn => {
  btn.addEventListener('click', () => {
    btns.forEach(b => b.classList.remove('btn-accent'));
    btn.classList.add('btn-accent');
    const cat = btn.dataset.cat;
    document.querySelectorAll('.cmd-card').forEach(card => {
      card.style.display = (cat === 'الكل' || card.dataset.cat === cat) ? '' : 'none';
    });
  });
});
btns[0].classList.add('btn-accent');
</script>
</body>
</html>
