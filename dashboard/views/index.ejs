<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Xtra Bot — أقوى بوت ديسكورد عربي</title>
  <meta name="description" content="بوت ديسكورد متكامل بأكثر من 99 أمر">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
  <a href="/" class="nav-brand">
    <div class="brand-logo">X</div>
    <span class="brand-name">Xtra</span>
    <span class="brand-version">v2.0</span>
  </a>
  <div class="nav-links">
    <a href="/" class="nav-link active"><i class="fas fa-home"></i> <span>الرئيسية</span></a>
    <a href="/commands" class="nav-link"><i class="fas fa-terminal"></i> <span>الأوامر</span></a>
    <a href="/premium" class="nav-link premium-link"><i class="fas fa-crown"></i> <span>بريميوم</span></a>
    <button class="lang-btn" onclick="toggleLang()">🌐 EN</button>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/dashboard" class="nav-link"><i class="fas fa-tachometer-alt"></i> <span>داشبورد</span></a>
      <div class="user-menu">
        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="user-avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'" alt="">
        <span class="user-name"><%= user.username %></span>
        <a href="/auth/logout" class="logout-btn" title="خروج"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    <% } else { %>
      <a href="/auth/login" class="login-btn"><i class="fab fa-discord"></i> تسجيل الدخول</a>
    <% } %>
  </div>
  <button class="mobile-toggle" onclick="document.querySelector('.nav-links').classList.toggle('active')"><i class="fas fa-bars"></i></button>
</nav>

<main>
<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">
      <span class="online-dot"></span>
      متصل على <strong style="color:var(--text);margin:0 .3rem"><%= totalGuilds %></strong> سيرفر الآن
    </div>
    <h1>Xtra Bot</h1>
    <p>أقوى بوت ديسكورد عربي — <strong style="color:var(--text)">99+ أمر</strong> بدون برفكس، داشبورد متجاوب، وميزات لا تنتهي 🚀</p>
    <div class="hero-btns">
      <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env.CLIENT_ID || '1481917947407765616' %>" target="_blank" class="btn btn-primary btn-lg">
        <i class="fab fa-discord"></i> أضف البوت مجاناً
      </a>
      <a href="/dashboard" class="btn btn-secondary btn-lg">
        <i class="fas fa-tachometer-alt"></i> فتح الداشبورد
      </a>
    </div>
    <div class="stats-grid">
      <div class="stat-card animate-fade">
        <div class="stat-icon">🌐</div>
        <div class="stat-number"><%= totalGuilds %></div>
        <div class="stat-label">سيرفر</div>
      </div>
      <div class="stat-card animate-fade">
        <div class="stat-icon">👥</div>
        <div class="stat-number"><%= totalUsers %></div>
        <div class="stat-label">مستخدم</div>
      </div>
      <div class="stat-card animate-fade">
        <div class="stat-icon">⚡</div>
        <div class="stat-number">99+</div>
        <div class="stat-label">أمر</div>
      </div>
      <div class="stat-card animate-fade">
        <div class="stat-icon">💓</div>
        <div class="stat-number" id="stat-ping">—</div>
        <div class="stat-label">ms Ping</div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<div class="section">
  <h2 class="section-title">🚀 مميزات Xtra Bot</h2>
  <p class="section-subtitle">كل ما تحتاجه لإدارة سيرفرك في بوت واحد متكامل</p>
  <div class="features-grid">
    <% const feats = [
      {i:'🎫',t:'نظام التذاكر',d:'تذاكر متكاملة بلوحة تحكم كاملة من الداشبورد، لوق وأزرار تخصيصية.'},
      {i:'🛡️',t:'حماية قصوى',d:'7 أنظمة حماية — سبام، روابط، كابس، منشن، ريد، حماية اسم وأيقونة السيرفر.'},
      {i:'📊',t:'نظام المستويات',d:'XP تلقائي مع بطاقات رتبة، رتب لكل مستوى، لوحة متصدرين رائعة.'},
      {i:'🎮',t:'ألعاب تفاعلية',d:'روليت، XO، نرد، حجرة ورقة مقص، خمّن الرقم، trivia وأكثر!'},
      {i:'🤖',t:'الردود التلقائية',d:'ردود ذكية بأنواع مطابقة مختلفة — exact, contains, startswith.'},
      {i:'⚡',t:'اختصارات الأوامر',d:'اعمل اختصارات لأي أمر بدون برفكس — مثل بروبوت تماماً!'},
      {i:'🎉',t:'نظام الهبات',d:'هبات تلقائية مع عداد مشاركين، إعادة سحب، وإنهاء تلقائي.'},
      {i:'✨',t:'زخرفة النصوص',d:'16+ شكل زخرفة مع نسخ تلقائي بضغطة واحدة.'},
      {i:'💤',t:'نظام AFK',d:'وضع الغياب مع إشعار تلقائي عند المنشن وتغيير الاسم.'},
      {i:'👑',t:'الرتب التلقائية',d:'رتب تلقائية للأعضاء والبوتات فور الانضمام للسيرفر.'},
      {i:'💎',t:'بريميوم',d:'تذاكر غير محدودة، إحصائيات متقدمة وميزات حصرية.'},
      {i:'🌐',t:'لغتان كاملتان',d:'دعم كامل للعربية والإنجليزية في البوت والداشبورد.'},
    ]; %>
    <% feats.forEach(f => { %>
    <div class="feature-card animate-fade">
      <div class="feature-icon"><%= f.i %></div>
      <h3><%= f.t %></h3>
      <p><%= f.d %></p>
    </div>
    <% }) %>
  </div>
</div>

<!-- CTA -->
<div style="text-align:center;padding:5rem 1.5rem;background:linear-gradient(180deg,transparent,rgba(88,101,242,.06));">
  <h2 style="font-size:2.2rem;font-weight:900;margin-bottom:1rem;">ابدأ الآن مجاناً 🎉</h2>
  <p style="color:var(--text2);margin-bottom:2.5rem;">أضف Xtra Bot لسيرفرك وابدأ الاستمتاع بكل الميزات</p>
  <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
    <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env.CLIENT_ID || '1481917947407765616' %>" target="_blank" class="btn btn-primary btn-lg"><i class="fab fa-discord"></i> أضف البوت</a>
    <a href="https://discord.gg/7UtgNs6xfK" target="_blank" class="btn btn-secondary btn-lg"><i class="fab fa-discord"></i> سيرفر الدعم</a>
    <a href="https://wa.me/201069181060" target="_blank" class="btn btn-secondary btn-lg" style="color:#25d366;border-color:rgba(37,211,102,.3);"><i class="fab fa-whatsapp"></i> واتساب</a>
  </div>
</div>
</main>

<%- include('partials/footer') %>
<script>
fetch('/api/ping').then(r=>r.json()).then(d=>{ if(d.ping !== undefined) document.getElementById('stat-ping').textContent = d.ping; }).catch(()=>{});
function toggleLang(){const h=document.documentElement;const ar=h.lang==='ar';h.lang=ar?'en':'ar';h.dir=ar?'ltr':'rtl';localStorage.setItem('lang',h.lang);document.querySelector('.lang-btn').textContent=ar?'🌐 AR':'🌐 EN';}
const sl=localStorage.getItem('lang');if(sl){document.documentElement.lang=sl;document.documentElement.dir=sl==='ar'?'rtl':'ltr';document.querySelector('.lang-btn').textContent=sl==='ar'?'🌐 EN':'🌐 AR';}
</script>
</body>
</html>
