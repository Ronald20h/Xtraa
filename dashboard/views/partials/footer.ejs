<script>
function toggleLang(){const h=document.documentElement;const ar=h.lang==='ar';h.lang=ar?'en':'ar';h.dir=ar?'ltr':'rtl';localStorage.setItem('lang',h.lang);const btn=document.querySelector('.lang-btn');if(btn)btn.textContent=ar?'🌐 AR':'🌐 EN';}
const sl=localStorage.getItem('lang');if(sl&&sl!=='ar'){document.documentElement.lang=sl;document.documentElement.dir='ltr';const btn=document.querySelector('.lang-btn');if(btn)btn.textContent='🌐 AR';}
</script>
