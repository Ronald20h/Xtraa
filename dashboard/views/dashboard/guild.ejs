<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> | Xtra Bot</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../layout', { title: guild.name, body: '' }) %>
  <div style="padding-top:65px;">
  <% if (typeof query !== 'undefined' && query.saved) { %>
    <div class="alert alert-success" style="margin:1rem 2rem;"><i class="fas fa-check"></i> تم الحفظ بنجاح!</div>
  <% } %>
  <div class="dashboard-layout">
    <!-- Sidebar -->
    <div class="sidebar">
      <div class="sidebar-guild">
        <% if (guild.icon) { %><img src="<%= guild.icon %>" alt=""><% } else { %><div class="no-icon" style="width:42px;height:42px;min-width:42px;font-size:1rem;"><%= guild.name.charAt(0) %></div><% } %>
        <div>
          <div class="guild-name"><%= guild.name %></div>
          <div class="guild-count">👥 <%= guild.memberCount %> عضو</div>
        </div>
      </div>
      <div class="sidebar-section">الإعدادات</div>
      <a href="#general" class="sidebar-link active"><i class="fas fa-cog"></i> عام</a>
      <a href="#welcome" class="sidebar-link"><i class="fas fa-door-open"></i> الترحيب</a>
      <a href="#protection" class="sidebar-link"><i class="fas fa-shield-alt"></i> الحماية</a>
      <a href="#tickets" class="sidebar-link"><i class="fas fa-ticket-alt"></i> التذاكر</a>
      <a href="#levels" class="sidebar-link"><i class="fas fa-chart-line"></i> المستويات</a>
      <a href="#autorespond" class="sidebar-link"><i class="fas fa-robot"></i> الردود التلقائية</a>
      <a href="#commands" class="sidebar-link"><i class="fas fa-terminal"></i> الأوامر</a>
      <a href="#logs" class="sidebar-link"><i class="fas fa-list"></i> اللوقات</a>
      <% if (premium) { %>
      <div class="sidebar-section">بريميوم ⭐</div>
      <div style="background:rgba(255,215,0,.1);border:1px solid rgba(255,215,0,.2);border-radius:8px;padding:.6rem;font-size:.8rem;color:var(--gold);text-align:center;">💎 هذا السيرفر مميز!</div>
      <% } %>
      <div style="margin-top:auto;padding-top:2rem;">
        <a href="/dashboard" class="sidebar-link"><i class="fas fa-arrow-right"></i> العودة</a>
      </div>
    </div>

    <!-- Content -->
    <div class="content">
      <form method="POST" action="/dashboard/guild/<%= guild.id %>/save">

        <!-- General -->
        <div id="general" class="card">
          <div class="card-title"><i class="fas fa-cog"></i> الإعدادات العامة</div>
          <div class="form-row">
            <div class="form-group">
              <label>🌐 لغة البوت</label>
              <select class="form-control" name="lang">
                <option value="ar" <%= guildData.lang === 'ar' ? 'selected' : '' %>>العربية 🇸🇦</option>
                <option value="en" <%= guildData.lang === 'en' ? 'selected' : '' %>>English 🇺🇸</option>
              </select>
            </div>
            <div class="form-group">
              <label>📋 قناة اللوقات</label>
              <select class="form-control" name="log_channel">
                <option value="">— اختر قناة —</option>
                <% channels.forEach(c => { %>
                  <option value="<%= c.id %>" <%= guildData.log_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <!-- Welcome -->
        <div id="welcome" class="card">
          <div class="card-title"><i class="fas fa-door-open"></i> إعدادات الترحيب</div>
          <div class="form-row">
            <div class="form-group">
              <label>📢 قناة الترحيب</label>
              <select class="form-control" name="welcome_channel">
                <option value="">— معطل —</option>
                <% channels.forEach(c => { %>
                  <option value="<%= c.id %>" <%= guildData.welcome_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>💬 رسالة الترحيب ({user} {server} {count})</label>
            <input class="form-control" name="welcome_message" placeholder="أهلاً {user} في {server}! 🎉" value="<%= guildData.welcome_message || '' %>">
          </div>
        </div>

        <!-- Protection -->
        <div id="protection" class="card">
          <div class="card-title"><i class="fas fa-shield-alt"></i> إعدادات الحماية</div>
          <div class="toggle-row">
            <div><strong>🚫 مضاد السبام</strong><br><small style="color:var(--text2)">يكتم العضو إذا أرسل 5 رسائل في 5 ثواني</small></div>
            <label class="toggle"><input type="checkbox" name="anti_spam" <%= guildData.anti_spam ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
          <div class="toggle-row">
            <div><strong>🔗 مضاد الروابط</strong><br><small style="color:var(--text2)">يحذف الروابط تلقائياً</small></div>
            <label class="toggle"><input type="checkbox" name="anti_links" <%= guildData.anti_links ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
          <div class="toggle-row">
            <div><strong>🔡 مضاد الكابس</strong><br><small style="color:var(--text2)">يحذف الرسائل ذات الكابس الكثير</small></div>
            <label class="toggle"><input type="checkbox" name="anti_caps" <%= guildData.anti_caps ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
          <div class="toggle-row">
            <div><strong>📢 مضاد المنشن الجماعي</strong><br><small style="color:var(--text2)">يحذف إذا منشن 5+ أشخاص</small></div>
            <label class="toggle"><input type="checkbox" name="anti_mention" <%= guildData.anti_mention ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
        </div>

        <!-- Tickets -->
        <div id="tickets" class="card">
          <div class="card-title"><i class="fas fa-ticket-alt"></i> نظام التذاكر</div>
          <div class="form-row">
            <div class="form-group">
              <label>🎫 الحد الأقصى للتذاكر (1-10)</label>
              <input type="number" class="form-control" name="max_tickets" min="1" max="10" value="<%= guildData.max_tickets || 5 %>">
            </div>
          </div>
          <div style="background:var(--bg3);border-radius:10px;padding:1rem;margin-top:.5rem;">
            <p style="font-size:.85rem;color:var(--text2);">📝 لإعداد لوحة التذاكر، استخدم:</p>
            <code style="background:var(--bg);padding:.3rem .6rem;border-radius:6px;font-size:.85rem;">/ticket setup</code> ثم <code style="background:var(--bg);padding:.3rem .6rem;border-radius:6px;font-size:.85rem;">/ticket panel</code>
          </div>
          <% if (tickets.length > 0) { %>
          <div class="table-wrap" style="margin-top:1rem;">
            <table><tr><th>المستخدم</th><th>الحالة</th><th>التاريخ</th></tr>
            <% tickets.forEach(t => { %><tr><td><@<%= t.user_id %>></td><td><span class="server-badge <%= t.status==='open'?'badge-bot':'badge-nobot' %>"><%= t.status==='open'?'✅ مفتوح':'🔒 مغلق' %></span></td><td style="font-size:.8rem;color:var(--text2);"><%= t.created_at %></td></tr><% }) %>
            </table>
          </div>
          <% } %>
        </div>

        <!-- Levels -->
        <div id="levels" class="card">
          <div class="card-title"><i class="fas fa-chart-line"></i> نظام المستويات</div>
          <div class="form-group">
            <label>📢 قناة إعلانات المستوى</label>
            <select class="form-control" name="level_channel">
              <option value="">— معطل —</option>
              <% channels.forEach(c => { %><option value="<%= c.id %>" <%= guildData.level_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option><% }) %>
            </select>
          </div>
          <% if (topMembers.length > 0) { %>
          <h4 style="margin:.8rem 0 .5rem;font-size:.9rem;">🏆 Top 5</h4>
          <% topMembers.forEach((m,i) => { const medals=['🥇','🥈','🥉']; %>
          <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.85rem;">
            <span><%= medals[i]||`#${i+1}` %> <@<%= m.user_id %>></span>
            <span style="color:var(--text2);">Lv.<%= m.level %> — <%= m.xp %> XP</span>
          </div>
          <% }) %>
          <% } %>
        </div>

        <div style="text-align:center;margin:2rem 0;">
          <button type="submit" class="btn btn-accent" style="padding:.8rem 3rem;font-size:1rem;"><i class="fas fa-save"></i> حفظ الإعدادات</button>
        </div>
      </form>

      <!-- Auto Respond -->
      <div id="autorespond" class="card">
        <div class="card-title"><i class="fas fa-robot"></i> الردود التلقائية (<%= autoresponds.length %>)</div>
        <form method="POST" action="/dashboard/guild/<%= guild.id %>/autorespond/add" style="display:grid;grid-template-columns:1fr 1fr auto auto;gap:.8rem;align-items:end;margin-bottom:1rem;">
          <div><label style="font-size:.8rem;color:var(--text2);">الكلمة المشغلة</label><input class="form-control" name="trigger" placeholder="مثال: هلا" required></div>
          <div><label style="font-size:.8rem;color:var(--text2);">الرد</label><input class="form-control" name="response" placeholder="مثال: هلا والله!" required></div>
          <div><label style="font-size:.8rem;color:var(--text2);">النوع</label><select class="form-control" name="match_type"><option value="exact">كاملة</option><option value="contains">يحتوي</option><option value="startswith">يبدأ بـ</option></select></div>
          <button type="submit" class="btn btn-accent"><i class="fas fa-plus"></i></button>
        </form>
        <% if (autoresponds.length > 0) { %>
        <div class="table-wrap"><table>
          <tr><th>الكلمة</th><th>الرد</th><th>النوع</th><th>الحالة</th><th>حذف</th></tr>
          <% autoresponds.forEach(r => { %>
          <tr>
            <td><code><%= r.trigger %></code></td>
            <td><%= r.response.substring(0,40) %><%= r.response.length>40?'...':'' %></td>
            <td style="font-size:.8rem;color:var(--text2);"><%= r.match_type %></td>
            <td><span class="server-badge <%= r.enabled?'badge-bot':'badge-nobot' %>"><%= r.enabled?'✅ مفعل':'❌ معطل' %></span></td>
            <td><form method="POST" action="/dashboard/guild/<%= guild.id %>/autorespond/delete/<%= r.id %>" style="display:inline;"><button type="submit" class="btn btn-danger" style="padding:.3rem .6rem;font-size:.8rem;">🗑️</button></form></td>
          </tr>
          <% }) %>
        </table></div>
        <% } else { %><p style="color:var(--text2);text-align:center;padding:1rem;">لا توجد ردود تلقائية</p><% } %>
      </div>

      <!-- Commands & Shortcuts -->
      <div id="commands" class="card">
        <div class="card-title"><i class="fas fa-terminal"></i> اختصارات الأوامر</div>
        <form method="POST" action="/dashboard/guild/<%= guild.id %>/command/shortcut" style="display:grid;grid-template-columns:1fr 1fr auto;gap:.8rem;align-items:end;margin-bottom:1rem;">
          <div><label style="font-size:.8rem;color:var(--text2);">اسم الأمر</label><input class="form-control" name="command_name" placeholder="مثال: ban" required></div>
          <div><label style="font-size:.8rem;color:var(--text2);">الاختصار (اكتبه في الشات)</label><input class="form-control" name="shortcut" placeholder="مثال: !ban" required></div>
          <button type="submit" class="btn btn-accent"><i class="fas fa-plus"></i></button>
        </form>
        <% if (commands.length > 0) { %>
        <div class="table-wrap"><table>
          <tr><th>الأمر</th><th>الاختصار</th></tr>
          <% commands.forEach(c => { %><tr><td>/<%= c.command_name %></td><td><code><%= c.shortcut || '—' %></code></td></tr><% }) %>
        </table></div>
        <% } %>
      </div>

      <!-- Logs -->
      <div id="logs" class="card">
        <div class="card-title"><i class="fas fa-list"></i> آخر اللوقات</div>
        <% if (logs.length > 0) { %>
        <div class="table-wrap"><table>
          <tr><th>النوع</th><th>المشرف</th><th>المستهدف</th><th>التفاصيل</th><th>التاريخ</th></tr>
          <% logs.forEach(l => { %>
          <tr><td><span class="server-badge badge-bot"><%= l.type %></span></td><td style="font-size:.8rem;"><@<%= l.user_id %>></td><td style="font-size:.8rem;"><@<%= l.target_id %>></td><td style="font-size:.8rem;color:var(--text2);"><%= (l.details||'').substring(0,30) %></td><td style="font-size:.75rem;color:var(--text2);"><%= l.created_at %></td></tr>
          <% }) %>
        </table></div>
        <% } else { %><p style="color:var(--text2);text-align:center;padding:1rem;">لا توجد لوقات</p><% } %>
      </div>

    </div>
  </div>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
