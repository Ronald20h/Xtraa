<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>داشبورد | Xtra Bot</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/nav') %>
<main style="padding-top:calc(var(--nav-h) + 2rem);">
<div class="section">
  <div class="page-header">
    <h1 style="font-size:1.8rem;"><i class="fas fa-server text-accent"></i> اختر سيرفرك</h1>
    <p style="color:var(--text2);">اختر السيرفر الذي تريد إدارته</p>
  </div>
  <div class="server-grid">
    <% guilds.forEach(g => { %>
    <% if (g.botInGuild) { %>
      <a href="/dashboard/guild/<%= g.id %>" class="server-card">
        <% if (g.iconURL) { %><img src="<%= g.iconURL %>" alt="<%= g.name %>"><% } else { %><div class="no-icon"><%= g.name.charAt(0) %></div><% } %>
        <h3><%= g.name %></h3>
        <% if (g.premium) { %><div class="server-badge badge-premium">💎 بريميوم</div><% } %>
        <div class="server-badge badge-bot">✅ البوت موجود</div>
      </a>
    <% } else { %>
      <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env.CLIENT_ID || '1481917947407765616' %>&permissions=8&scope=bot%20applications.commands&guild_id=<%= g.id %>" target="_blank" class="server-card">
        <% if (g.iconURL) { %><img src="<%= g.iconURL %>" alt="<%= g.name %>"><% } else { %><div class="no-icon"><%= g.name.charAt(0) %></div><% } %>
        <h3><%= g.name %></h3>
        <div class="server-badge badge-nobot">➕ أضف البوت</div>
      </a>
    <% } %>
    <% }) %>
  </div>
</div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
